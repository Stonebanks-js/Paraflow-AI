# ==========================================
# OPTIONAL - AI Providers (enhances functionality)
# ==========================================

# Anthropic (Claude) - Leave empty to use demo mode
ANTHROPIC_API_KEY=

# Groq (fast + free tier available) - RECOMMENDED for production
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (aggregator, many free models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=

# Claude Model
AI_MODEL_SONNET=claude-3-5-sonnet-20241022

# ==========================================
# LLM PROVIDER SELECTION
# ==========================================

# Which provider to use. Options: groq, openai, openrouter, gemini
ACTIVE_PROVIDER=groq

# Override the provider's default model. Leave empty to use the provider default
ACTIVE_MODEL=

# Comma-separated fallback chain if the active provider fails
FALLBACK_PROVIDERS=openrouter,gemini

# Hard timeout per provider call (seconds)
LLM_TIMEOUT_SECONDS=10

# ==========================================
# APPLICATION SETTINGS
# ==========================================

APP_NAME=Paraflow AI
APP_VERSION=1.0.0
DEBUG=False
DEMO_MODE=False

# CORS Origins (comma-separated - UPDATE with your frontend URL)
CORS_ORIGINS=http://localhost:3000,https://paraflow-ai-frontend.vercel.app

# Port (set automatically by Render)
PORT=8000
