# Paraflow AI Backend

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/paraflow
REDIS_URL=redis://localhost:6379/0

# Supabase Configuration (required for authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI API Keys (optional - falls back to simulation mode if not set)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Debug mode
DEBUG=true