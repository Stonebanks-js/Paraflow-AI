# Paraflow AI - Environment Variables Template
# Copy this file to .env and fill in your values

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# Application
APP_NAME=Paraflow AI
APP_VERSION=1.0.0
DEBUG=false

# Demo Mode (set to false for production with Supabase)
DEMO_MODE=true

# Supabase (leave empty for demo mode)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# NVIDIA (for production AI engines)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# AI Model Configuration
AI_MODEL_HAIKU=claude-3-haiku-20240307
AI_MODEL_SONNET=claude-3-5-sonnet-20241022
AI_MODEL_GEMINI_FLASH=gemini-2.0-flash
AI_MODEL_GEMINI_PRO=gemini-1.5-pro

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=60
RATE_LIMIT_TEAM=120

# Optional: Cloudflare (for CAPTCHA, etc.)
CLOUDFLARE_API_KEY=

# Optional: Stripe (for payments)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: S3 Storage
S3_BUCKET=paraflow-ai
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================

# API URL (point to your backend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Supabase (for auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=