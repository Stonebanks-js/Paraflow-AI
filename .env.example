# Paraflow AI - Environment Variables Template
# Copy this file to .env and fill in your values

# ==========================================
# BACKEND - REQUIRED
# ==========================================

SUPABASE_URL=https://txpatnmsigkmmgrbhbel.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

JWT_SECRET_KEY=your-super-secret-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# BACKEND - OPTIONAL (for enhanced AI)
# ==========================================

# Anthropic API (for Claude)
ANTHROPIC_API_KEY=

# NVIDIA API (for NVIDIA AI)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# Claude Model
AI_MODEL_SONNET=claude-3-5-sonnet-20241022

# ==========================================
# BACKEND - APPLICATION
# ==========================================

APP_NAME=Paraflow AI
APP_VERSION=1.0.0
DEBUG=False
DEMO_MODE=False

# CORS - Update with your frontend URL
CORS_ORIGINS=http://localhost:3000,https://paraflow-ai-frontend.vercel.app

# Port (auto-set by Render)
PORT=8000

# ==========================================
# FRONTEND
# ==========================================

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SUPABASE_URL=https://txpatnmsigkmmgrbhbel.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
